# ───────────────────────────────────────────────────────────────────────────
# KIS Trading MCP 환경설정 템플릿
#
# 사용법: 이 파일을 복사해서 환경별 파일을 만들고 값을 채우세요.
#   cp .env.example .env.paper   # 모의투자 (ENV=paper)  ← 처음엔 이걸 권장
#   cp .env.example .env.live    # 실전투자 (ENV=live)
#
# .env.paper / .env.live 는 .gitignore 로 git 에 올라가지 않습니다(비밀 보호).
# server.py 는 ENV 환경변수(paper|live)에 맞춰 .env.{ENV} 를 읽습니다.
# ───────────────────────────────────────────────────────────────────────────

# MCP 전송 방식 — Claude Code / Claude Desktop / Cursor(stdio) 는 stdio 고정
MCP_TYPE=stdio

# ===========================================================================
# [방식 A · 기본] 평문으로 직접 입력  ← 가장 단순. 누구나/어떤 모델이든 따라할 수 있음
# 한국투자증권 개발자센터(https://apiportal.koreainvestment.com/)에서 발급받은 값
# ===========================================================================
KIS_APP_KEY=발급받은_실전_APP_KEY
KIS_APP_SECRET=발급받은_실전_APP_SECRET
KIS_PAPER_APP_KEY=발급받은_모의_APP_KEY
KIS_PAPER_APP_SECRET=발급받은_모의_APP_SECRET
KIS_HTS_ID=내_HTS_ID
KIS_ACCT_STOCK=12345678          # 실전 주식 계좌번호 앞 8자리
KIS_ACCT_FUTURE=12345678         # 실전 선물옵션 계좌번호 앞 8자리 (주식과 같아도 됨)
KIS_PAPER_STOCK=50123456         # 모의 주식 계좌번호
KIS_PAPER_FUTURE=50123456        # 모의 선물옵션 계좌번호 (주식과 같아도 됨)
KIS_PROD_TYPE=01                 # 계좌번호 뒤 2자리: 01 종합 / 03 국내선옵 / 08 해외선옵 / 22 개인연금 / 29 퇴직연금

# ===========================================================================
# [방식 B · 보안 강화] 1Password op:// 참조 (선택)
# 위 평문 값 대신 아래처럼 op:// 참조를 적으면, 서버 기동 시 1Password 에서
# 실제 값을 읽어 치환합니다. 평문 비밀이 디스크에 남지 않습니다.
# 1Password CLI(op) 또는 데스크톱 앱이 필요합니다(자세한 건 Readme.md 참고).
# 방식 B 를 쓸 땐 위 [방식 A] 줄을 지우고 아래 주석을 해제하세요.
# ===========================================================================
# OP_ACCOUNT=my.1password.com
# KIS_APP_KEY=op://Private/kis-trading/KIS_APP_KEY
# KIS_APP_SECRET=op://Private/kis-trading/KIS_APP_SECRET
# KIS_PAPER_APP_KEY=op://Private/kis-trading/KIS_PAPER_APP_KEY
# KIS_PAPER_APP_SECRET=op://Private/kis-trading/KIS_PAPER_APP_SECRET
# KIS_HTS_ID=op://Private/kis-trading/KIS_HTS_ID
# KIS_ACCT_STOCK=op://Private/kis-trading/KIS_ACCT_STOCK
# KIS_ACCT_FUTURE=op://Private/kis-trading/KIS_ACCT_FUTURE
# KIS_PAPER_STOCK=op://Private/kis-trading/KIS_PAPER_STOCK
# KIS_PAPER_FUTURE=op://Private/kis-trading/KIS_PAPER_FUTURE
# KIS_PROD_TYPE=01
